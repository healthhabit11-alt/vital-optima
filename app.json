{
  "expo": {
    "name": "Vital Optima",
    "slug": "vital-optima",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vitaloptima",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vitaloptima.app"
    },
    "android": {
      "package": "com.vitaloptima.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B4332"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#1B4332",
          "resizeMode": "contain"
        }
      ],
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "color": "#1B4332",
          "defaultChannel": "default",
          "androidMode": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "330bd385-4e7d-4b80-b324-4a9bba149f17"
      }
    },
    "owner": "healthhabitat"
  }
}
